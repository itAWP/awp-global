{
  "buildCommand": "",
  "installCommand": "",
  "framework": null,
  "outputDirectory": ".",
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://public.codepenassets.com; img-src 'self' data: blob: https://mrdoob.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/send_email.php",
      "destination": "/404.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*\\.env.*)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.git.*)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.htaccess.*)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.sql)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.bak)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.zip)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.tar\\.gz)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.log)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/:path(.*\\.php)",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/wp-admin/:path*",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/wp-login.php",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/wp-content/:path*",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/config/:path*",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/admin/:path*",
      "destination": "/404.html",
      "statusCode": 404
    },
    {
      "source": "/debug.log",
      "destination": "/404.html",
      "statusCode": 404
    }
  ]
}
